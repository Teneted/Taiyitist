{
  "required": true,
  "minVersion": "0.8",
  "plugin": "com.taiyitistmc.mixin.TaiyitistMixinPlugin",
  "package": "com.taiyitistmc.mixin",
  "compatibilityLevel": "JAVA_21",
  "overwrites": {
    "conformVisibility": true
  },
  "injectors": {
    "maxShiftBy": 2,
    "defaultRequire": 1
  },
  "mixinPriority": 400,
  "mixins": [
    "advancements.MixinAdvancementHolder",
    "advancements.MixinAdvancementTree",
    "commands.MixinCommandNode",
    "commands.MixinCommands",
    "commands.MixinCommandSource",
    "commands.MixinCommandSource1",
    "commands.MixinCommandSourceStack",
    "commands.arguments.MixinEntityArgument",
    "commands.arguments.blocks.MixinBlockStateParser",
    "commands.arguments.selector.MixinEntitySelectorParser",
    "network.MixinConnection",
    "network.syncher.MixinSynchedEntityData",
    "server.MixinMain",
    "server.MixinMinecraftServer",
    "server.MixinWorldLoader",
    "server.dedicated.MixinDedicatedServer",
    "server.level.MixinServerLevel",
    "server.level.MixinTicketType",
    "server.players.MixinPlayerList",
    "stats.MixinServerRecipeBook",
    "stats.MixinStatsCounter",
    "util.MixinSpawnUtil",
    "util.MixinTickThrottler",
    "world.level.MixinLevel",
    "world.level.block.MixinDispenserBlock",
    "world.level.block.MixinSaplingBlock",
