{
  "required": true,
  "minVersion": "0.8",
  "plugin": "com.taiyitistmc.mixin.TaiyitistMixinPlugin",
  "package": "com.taiyitistmc.mixin",
  "compatibilityLevel": "JAVA_21",
  "overwrites": {
    "conformVisibility": true
  },
  "injectors": {
    "maxShiftBy": 2,
    "defaultRequire": 1
  },
  "mixinPriority": 400,
  "mixins": [
    "server.MixinMain",
    "server.MixinMinecraftServer",
    "server.MixinWorldLoader",
    "server.dedicated.MixinDedicatedServer",
    "server.level.MixinServerLevel",
    "server.level.MixinTicketType",
    "server.players.MixinPlayerList",
    "world.level.MixinLevel",
    "world.level.block.MixinDispenserBlock",
    "world.level.block.MixinSaplingBlock",
    "world.level.item.MixinSignItem"
  ]
}
